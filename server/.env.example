# ============================================
# SmileX Dict 环境变量配置
# 复制此文件为 .env 并根据环境修改相应值
# 所有配置项均有默认值，可按需覆盖
# ============================================

# ---------- 应用 ----------

# 应用名称
APP_NAME=SmileX Dict

# 运行环境: development | production
# production 时禁用 /docs 和 /redoc API 文档
APP_ENV=development

# 调试模式: true | false
DEBUG=false

# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 日志输出目录（相对于 server/）
LOG_DIR=logs

# ---------- 安全 ----------

# JWT 签名密钥，生产环境务必更换为随机长字符串
# 可用: python -c "import secrets; print(secrets.token_urlsafe(32))"
ALGORITHM=HS256

# JWT Token 过期天数
ACCESS_TOKEN_EXPIRE_DAYS=7

# ⚠️ 生产环境必须设置，替换下方默认值
SECRET_KEY=your-very-secure-random-secret-key-here

# ---------- 数据库 ----------

# 数据库连接字符串
# SQLite:   sqlite:///./data/smilex.db
# PostgreSQL: postgresql://user:password@localhost:5432/smilex_dict
DATABASE_URL=sqlite:///./data/smilex.db

# ---------- CORS ----------

# 允许的跨域来源，JSON 数组格式
# 开发环境: ["*"]
# 生产环境: ["https://your-domain.com", "https://app.your-domain.com"]
ALLOWED_ORIGINS=["*"]

# ---------- 限流 ----------

# 每分钟每个 IP 最大请求数
RATE_LIMIT_PER_MINUTE=60

# ---------- 文件上传 ----------

# TXT 文件上传大小上限（MB）
MAX_UPLOAD_SIZE_MB=5

# 批量导入单词上限（异步模式，含在线查词）
MAX_BULK_IMPORT_WORDS=5000

# 快速导入单词上限（同步模式，仅导入单词文本）
MAX_QUICK_IMPORT_WORDS=200

# 异步批量导入时每批处理数量
TXT_IMPORT_BATCH_SIZE=20
